{
  "manifest_version": 3,
  "name": "블로그 포스팅 도우미",
  "version": "1.0.0",
  "description": "네이버 스마트스토어 / 지도에서 데이터를 수집해 블로그 포스팅을 자동 생성합니다.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "https://smartstore.naver.com/*",
    "https://brand.naver.com/*",
    "https://brandconnect.naver.com/*",
    "https://map.naver.com/*",
    "https://blog.naver.com/*",
    "https://*.public.blob.vercel-storage.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://smartstore.naver.com/*",
        "https://brand.naver.com/*",
        "https://brandconnect.naver.com/*"
      ],
      "js": ["content/smartstore.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://map.naver.com/*"],
      "js": ["content/navermap.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://blog.naver.com/*"],
      "js": ["content/naverblog.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
